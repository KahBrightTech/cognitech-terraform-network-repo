# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL database connection details
DB_HOST=your-database-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=africaletstalk
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# ==================== SECURITY ====================
# JWT Secret for authentication tokens (generate a random 64+ character string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==================== EMAIL CONFIGURATION (REQUIRED) ====================
# Email verification requires SMTP settings to be configured
# Without these, users cannot verify their accounts and will not be able to login

# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Gmail SMTP Credentials
# For Gmail: Use an App Password, not your regular password
# 1. Enable 2-factor authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
# 4. Use that app password below
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Alternative SMTP Providers:
# - SendGrid: smtp.sendgrid.net (port 587)
# - Mailgun: smtp.mailgun.org (port 587)
# - Amazon SES: email-smtp.us-east-1.amazonaws.com (port 587)
# - Outlook: smtp-mail.outlook.com (port 587)

# Frontend URL (used for email verification links)
# This should be your public website URL
FRONTEND_URL=http://localhost

# ==================== DOCKER NETWORK ====================
# Backend URL for nginx proxy (used by frontend container)
# Format: http://backend:3000
# In production, this could be a load balancer or ECS service URL
BACKEND_URL=http://backend:3000

# ==================== NOTES ====================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. SMTP credentials are REQUIRED for user registration and login
# 4. Old users getting "invalid credentials" likely means:
#    - Database was reset and users need to re-register
#    - Email verification is not complete
# 5. New users getting "network error" likely means:
#    - BACKEND_URL is not properly configured in docker-compose
#    - Backend container is not accessible from frontend
#    - Check docker logs: docker-compose logs backend
