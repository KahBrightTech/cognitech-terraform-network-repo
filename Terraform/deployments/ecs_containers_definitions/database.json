[
  {
    "name": "database",
    "image": "730335294148.dkr.ecr.us-east-1.amazonaws.com/int-preproduction-use1-ecs:database-latest",
    "cpu": 1024,
    "memory": 2048,
    "essential": true,
    "portMappings": [
      {
        "containerPort": 5432,
        "protocol": "tcp"
      }
    ],
    "environment": [
      {
        "name": "POSTGRES_DB",
        "value": "africaletstalk"
      },
      {
        "name": "POSTGRES_USER",
        "value": "postgres"
      },
      {
        "name": "POSTGRES_PASSWORD",
        "value": "postgres"
      }
    ],
    "mountPoints": [
      {
        "sourceVolume": "database-storage",
        "containerPath": "/var/lib/postgresql/data",
        "readOnly": false
      }
    ],
    "healthCheck": {
      "command": ["CMD-SHELL", "pg_isready -U postgres || exit 1"],
      "interval": 30,
      "timeout": 5,
      "retries": 3,
      "startPeriod": 60
    },
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/database",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "ecs",
        "awslogs-create-group": "true"
      }
    }
  }
]