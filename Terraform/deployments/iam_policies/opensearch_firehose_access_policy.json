{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAdminRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "[[admin_role_arn]]"
      },
      "Action": "es:ESHttp*",
      "Resource": "arn:aws:es:[[region]]:[[account_number]]:domain/[[resource_name]]/*"
    },
    {
      "Sid": "AllowFromMyPublicIP",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "es:ESHttp*",
      "Resource": "arn:aws:es:[[region]]:[[account_number]]:domain/[[resource_name]]/*",
      "Condition": {
        "IpAddress": {
          "aws:SourceIp": "[[source_ip]]"
        }
      }
    }
  ]
}