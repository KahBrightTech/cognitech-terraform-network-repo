{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FirehoseS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::[[account_name]]-[[region_prefix]]-dev-firehose-bucket*",
        "arn:aws:s3:::[[account_name]]-[[region_prefix]]-dev-*/*"
      ]
    },
    {
      "Sid": "FirehoseOpenSearchAccess",
      "Effect": "Allow",
      "Action": [
        "es:DescribeElasticsearchDomain",
        "es:DescribeElasticsearchDomains",
        "es:DescribeElasticsearchDomainConfig",
        "es:ESHttpPost",
        "es:ESHttpPut",
        "es:ESHttpGet"
      ],
      "Resource": [
        "arn:aws:es:*:*:domain/*",
        "arn:aws:es:*:*:domain/*/*"
      ]
    }
  ]
}
