{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Allow s3 access to firehose role only",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::[[account_number]]:role/[[account_name]]-[[region_prefix]]-shared-firehose-role"
      },
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:PutBucketPolicy"
      ],
      "Resource": [
        "arn:aws:s3:::[[resource_name]]",
        "arn:aws:s3:::[[resource_name]]/*"
      ]
    },
    {
      "Sid": "Allow s3 access to admin role",
      "Effect": "Allow",
      "Principal": {
        "AWS": "*"
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::[[resource_name]]",
        "arn:aws:s3:::[[resource_name]]/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": ["us-east-1", "us-west-2"],
          "aws:PrincipalArn": ["[[admin_role]]", "[[github_oidc_role]]"]
        }
      }
    }
  ]
}
